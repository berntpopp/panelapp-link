# PanelApp-Link configuration. Copy to .env and adjust. All vars are PANELAPP_LINK_*.
# Nested data config uses a double underscore, e.g. PANELAPP_LINK_DATA__UK_API_URL.

# --- Server ---
PANELAPP_LINK_HOST=127.0.0.1
PANELAPP_LINK_PORT=8000
PANELAPP_LINK_TRANSPORT=unified
PANELAPP_LINK_MCP_PATH=/mcp

# --- Logging ---
PANELAPP_LINK_LOG_LEVEL=INFO
PANELAPP_LINK_LOG_FORMAT=console

# --- PanelApp live API (no auth, no local database) ---
# Base URLs for the two regions (override only for mirrors/testing).
PANELAPP_LINK_DATA__UK_API_URL=https://panelapp.genomicsengland.co.uk/api/v1
PANELAPP_LINK_DATA__AU_API_URL=https://panelapp-aus.org/api/v1
# Per-request HTTP timeout (seconds).
PANELAPP_LINK_DATA__REQUEST_TIMEOUT=60
# Politeness toward PanelApp's per-IP rate limit (429 / Retry-After aware).
PANELAPP_LINK_DATA__MAX_CONCURRENCY=4
PANELAPP_LINK_DATA__MAX_RETRIES=5

# --- In-memory query cache (0 size disables) ---
PANELAPP_LINK_DATA__CACHE_SIZE=512
PANELAPP_LINK_DATA__CACHE_TTL=21600
