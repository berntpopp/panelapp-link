# PanelApp-Link configuration. Copy to .env and adjust. All vars are PANELAPP_LINK_*.
# Nested data config uses a double underscore, e.g. PANELAPP_LINK_DATA__DB_FILENAME.

# --- Server ---
PANELAPP_LINK_HOST=127.0.0.1
PANELAPP_LINK_PORT=8000
PANELAPP_LINK_TRANSPORT=unified
PANELAPP_LINK_MCP_PATH=/mcp

# --- Logging ---
PANELAPP_LINK_LOG_LEVEL=INFO
PANELAPP_LINK_LOG_FORMAT=console

# --- Data source / local store ---
# PanelApp REST API base URLs (no auth).
PANELAPP_LINK_DATA__UK_API_URL=https://panelapp.genomicsengland.co.uk/api/v1
PANELAPP_LINK_DATA__AU_API_URL=https://panelapp-aus.org/api/v1
# Directory for the built SQLite database (default: <repo>/data).
# PANELAPP_LINK_DATA__DATA_DIR=/data
PANELAPP_LINK_DATA__DB_FILENAME=panelapp.sqlite
PANELAPP_LINK_DATA__REQUEST_TIMEOUT=60
PANELAPP_LINK_DATA__MAX_CONCURRENCY=8
PANELAPP_LINK_DATA__MAX_RETRIES=4
# Build the database on first use by crawling the APIs if it is absent.
PANELAPP_LINK_DATA__AUTO_BOOTSTRAP=true
# In-app conditional-refresh scheduler (unified/http transports only). Disable
# when an external scheduler (cron sidecar, k8s CronJob) owns refresh.
PANELAPP_LINK_DATA__REFRESH_ENABLED=true
PANELAPP_LINK_DATA__REFRESH_INTERVAL_HOURS=24
PANELAPP_LINK_DATA__REFRESH_JITTER_SECONDS=300
# Seconds to wait for the cross-process build lock before giving up.
PANELAPP_LINK_DATA__BUILD_LOCK_TIMEOUT=600
# Query cache (0 disables).
PANELAPP_LINK_DATA__CACHE_SIZE=512
PANELAPP_LINK_DATA__CACHE_TTL=3600
