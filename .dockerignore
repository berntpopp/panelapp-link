# Keep Docker build contexts small and reproducible.

.git
.github/
.gitignore
.gitattributes

__pycache__/
*.py[cod]
*$py.class
*.so

.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/
wheels/

.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
htmlcov/
.coverage
.coverage.*
coverage.xml

# Do not ship the built SQLite database into the image; the entrypoint builds it.
data/

.env
.env.*
!.env.example
!.env.docker.example

docs/
scripts/
tests/

# Exclude docker/ build + compose files from the context, but KEEP
# entrypoint.sh — the Dockerfile copies it into the image.
docker/*
!docker/entrypoint.sh
Dockerfile*
docker-compose*.yml

*.log
*.tmp
*.temp
*.bak
.DS_Store
Thumbs.db
