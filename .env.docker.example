# Docker environment for panelapp-link behind Nginx Proxy Manager.
# Copy to .env.docker for the NPM compose deployment:
#
#   cp .env.docker.example .env.docker
#
# All keys are optional (the image and docker-compose.npm.yml carry safe
# defaults); this file mainly pins the external NPM network and lets you tune
# logging / caching without editing the compose file.

# ---- Nginx Proxy Manager (docker-compose.npm.yml) ----
# External NPM network the container joins for reverse-proxy routing.
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Logging ----
LOG_LEVEL_API=INFO

# ---- Query cache ----
PANELAPP_CACHE_SIZE=2000
PANELAPP_CACHE_TTL=7200

# ---- NPM resource limits (optional) ----
PANELAPP_API_MEMORY_LIMIT=1g
PANELAPP_API_CPU_LIMIT=1.0
