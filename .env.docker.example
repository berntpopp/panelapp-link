# Docker environment for panelapp-link.
# Copy to .env.docker for the compose deployment:
#
#   cp .env.docker.example .env.docker
#
# All keys are optional; docker/docker-compose.yml carries safe defaults and
# loads this file only if present. All variables use the PANELAPP_LINK_ prefix
# (nested data config uses a double underscore, e.g. PANELAPP_LINK_DATA__*).

# ---- Published host port (maps to container :8000) ----
PANELAPP_LINK_HOST_PORT=8000

# ---- Server / transport ----
PANELAPP_LINK_TRANSPORT=unified
PANELAPP_LINK_MCP_PATH=/mcp

# ---- Logging (JSON is recommended in containers) ----
PANELAPP_LINK_LOG_LEVEL=INFO
PANELAPP_LINK_LOG_FORMAT=json

# ---- PanelApp API endpoints (override only for mirrors/testing) ----
# PANELAPP_LINK_DATA__UK_API_URL=https://panelapp.genomicsengland.co.uk/api/v1
# PANELAPP_LINK_DATA__AU_API_URL=https://panelapp-aus.org/api/v1

# ---- In-memory query cache (pure live-API client; no database) ----
PANELAPP_LINK_DATA__CACHE_SIZE=2000
PANELAPP_LINK_DATA__CACHE_TTL=21600
# Politeness toward PanelApp's per-IP rate limit:
PANELAPP_LINK_DATA__MAX_CONCURRENCY=4
PANELAPP_LINK_DATA__MAX_RETRIES=5
